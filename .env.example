# BookFree environment template
#
# Copy to `.env` (or export in your process manager) and fill in the
# values that apply to your deployment. The Go server reads env via
# os.Getenv at boot — there is no .env auto-loader by design, so a
# typo can't silently make production read dev secrets.
#
# Only the variables marked "required in prod" must be set in
# production deployments. Everything else has a sane default.

# ─── core ────────────────────────────────────────────────────────────

# `production` switches on stricter security defaults: secure cookie,
# panic-stack hiding, registration disabled by default, hard-fail on
# missing app secret.
BOOKFREE_ENV=production

# Where the server listens. Bind to localhost behind a reverse proxy.
BOOKFREE_ADDR=127.0.0.1:8788

# `info` | `debug` | `warn` | `error`. Defaults to `info`.
BOOKFREE_LOG_LEVEL=info

# ─── secrets ─────────────────────────────────────────────────────────

# REQUIRED IN PROD. 32+ random hex bytes.
# All of: AES key derivation for ai_providers, session token derivation,
# OAuth state encryption.  In production, missing this aborts boot.
#
# Migration compatibility: the loader also accepts QS_MASTER_SECRET,
# APP_SECRET, NEXTAUTH_SECRET, SESSION_SECRET, or QS_CONFIG_SECRET —
# in that order — so legacy deployments can promote in place.
BOOKFREE_APP_SECRET=

# ─── storage ─────────────────────────────────────────────────────────

# SQLite file URL. `file:./data/bookfree.db` is fine for single-host.
# Remote libsql:// URLs are rejected by this build (Phase 1 only
# supports local SQLite — see docs/MIGRATION-PROGRESS.md).
#
# Migration compat: TURSO_DATABASE_URL is read if BOOKFREE_DB_URL is
# unset.
BOOKFREE_DB_URL=file:./data/bookfree.db

# Where book files live. The directory is created if it doesn't exist.
BOOKFREE_STORAGE_DIR=./data/storage

# Per-upload cap in MB. Streaming upload code enforces this both
# pre-flight (Content-Length check) and mid-stream (MaxBytesReader).
BOOKFREE_MAX_UPLOAD_SIZE_MB=200

# ─── auth ────────────────────────────────────────────────────────────

# Session cookie name. Match the legacy default so existing logged-in
# users carry over.  Legacy: AUTH_COOKIE_NAME.
BOOKFREE_SESSION_COOKIE=alma_session

# In dev, registration is enabled. In prod it's disabled by default.
# Set to `1` or `true` to allow self-serve registration in prod.
# Set to `0` or `false` to force-disable in dev.
# BOOKFREE_ALLOW_REGISTRATION=

# ─── frontend ────────────────────────────────────────────────────────

# Optional disk override of the embedded SPA. Useful in dev — set to
# `apps/web/dist` and the server reads files from disk on every
# request, so a `npm run build` is enough to refresh assets without
# recompiling the binary.
# BOOKFREE_WEBDIST_DIR=apps/web/dist

# ─── runtime ─────────────────────────────────────────────────────────

# Hard memory ceiling. Defaults to 80 MiB, set in main.go.
# Set explicitly here to override.
# GOMEMLIMIT=80MiB

# ─── ai (optional) ───────────────────────────────────────────────────

# Anthropic API key for the in-reader AI chat panel. If unset, the
# panel surfaces a friendly "AI 未配置" notice and /api/ai/chat returns
# 501 NOT_CONFIGURED — chat never silently degrades.
# ANTHROPIC_API_KEY=

# Time zone for log timestamps and X-Date response header.
# TZ=Asia/Shanghai
